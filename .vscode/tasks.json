{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: Run main.py",
      "type": "shell",
      "command": "${workspaceFolder}/venv/Scripts/python.exe",
      "args": ["main.py"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$python"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Python: Activate venv and run",
      "type": "shell",
      "command": "${workspaceFolder}/venv/Scripts/activate && python main.py",
      "group": "test",
      "problemMatcher": ["$python"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
